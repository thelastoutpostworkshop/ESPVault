{
  "name": "esp-board-vault",
  "version": "1.0.5",
  "description": "A local-first desktop notebook for ESP32 board inventory.",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run typecheck && vite build && node scripts/build-electron.mjs",
    "typecheck": "vue-tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.electron.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "chart.js": "^4.5.1",
    "dexie": "^4.4.2",
    "pinia": "^3.0.3",
    "tasmota-webserial-esptool": "^9.2.21",
    "vue": "^3.5.18",
    "vuetify": "^4.0.7"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/w3c-web-serial": "^1.0.8",
    "@vitejs/plugin-vue": "^6.0.1",
    "electron": "^42.0.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vue-tsc": "^3.0.5"
  }
}
