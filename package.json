{
  "name": "esp-board-vault",
  "desktopName": "esp-board-vault.desktop",
  "version": "1.0.29",
  "description": "A local-first desktop notebook for ESP32 board inventory.",
  "author": "The Last Outpost Workshop",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:browser": "node scripts/browser-harness.mjs",
    "build": "npm run typecheck && vite build && node scripts/build-electron.mjs",
    "package": "node scripts/package.mjs",
    "package:win": "node scripts/package.mjs --win --x64",
    "package:mac": "node scripts/package.mjs --mac --x64 --arm64",
    "package:linux": "node scripts/package.mjs --linux --x64",
    "test": "vitest run",
    "test:visual": "node scripts/test-visual.mjs",
    "test:visual:headed": "node scripts/test-visual.mjs --headed",
    "typecheck": "vue-tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.electron.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "chart.js": "^4.5.1",
    "dexie": "^4.4.2",
    "pinia": "^3.0.3",
    "tasmota-webserial-esptool": "^9.2.21",
    "vue": "^3.5.18",
    "vuetify": "^4.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.2",
    "@types/w3c-web-serial": "^1.0.8",
    "@vitejs/plugin-vue": "^6.0.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "fake-indexeddb": "^6.2.5",
    "resedit": "^3.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.0.5"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "esbuild@0.28.0": true
  }
}
